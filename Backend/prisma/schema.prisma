generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Specialty {
  id      Int     @id @default(autoincrement())
  name    String  @unique
  queues  Queue[]
  doctors User[]
}

model Role {
  id    Int    @id @default(autoincrement())
  name  String
  users User[]
}

model User {
  id              Int             @id @default(autoincrement())
  email           String          @unique
  name            String
  phone           String?
  dateOfBirth     DateTime        @db.Date
  passwordHash    String
  createdAt       DateTime        @default(now())
  roleId          Int
  isActive        Boolean         @default(true)
  isSuperAdmin    Boolean         @default(false)
  profileImage    String?
  profilePublicId String?
  specialtyId     Int?
  appointments    Appointment[]
  invoices        Invoice[]
  medicalRecords  MedicalRecord[]
  prescriptions   Prescription[]
  queues          Queue[]         @relation("CurrentQueueUser")
  queueHistories  QueueHistory[]  @relation("QueueHistoryUser")
  refreshTokens   RefreshToken[]
  triages         Triage[]
  role            Role            @relation(fields: [roleId], references: [id], onDelete: Cascade)
  specialty       Specialty?      @relation(fields: [specialtyId], references: [id])
}

model Patient {
  id             Int             @id @default(autoincrement())
  fullName       String
  gender         Gender
  phone          String          @unique
  address        String?
  dateOfBirth    DateTime
  createdAt      DateTime        @default(now())
  appointments   Appointment[]
  invoices       Invoice[]
  medicalRecords MedicalRecord[]
  prescriptions  Prescription[]
  queues         Queue[]
}

model Appointment {
  id              Int               @id @default(autoincrement())
  reason          String?
  appointmentDate DateTime
  status          AppointmentStatus @default(PENDING)
  createdAt       DateTime          @default(now())
  userId          Int
  patientId       Int
  endTime         DateTime
  startTime       DateTime
  patient         Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoice         Invoice?
  medicalRecord   MedicalRecord?
  prescriptions   Prescription[]
  queue           Queue?
  triage          Triage?

  @@index([userId])
  @@index([patientId])
}

model Medication {
  id                      Int                      @id @default(autoincrement())
  name                    String                   @unique
  description             String
  stockQuantity           Int
  unitPrice               Decimal                  @db.Decimal(10, 2)
  prescriptionMedications PrescriptionMedication[]
}

model InvoiceItem {
  id          Int     @id @default(autoincrement())
  unitPrice   Decimal @db.Decimal(10, 2)
  description String
  type        String
  subTotal    Decimal @db.Decimal(10, 2)
  quantity    Int
  invoiceId   Int
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model Invoice {
  id            Int           @id @default(autoincrement())
  paymentMethod String
  issuedDate    DateTime
  paymentStatus PaymentStatus @default(UNPAID)
  totalAmount   Decimal       @db.Decimal(10, 2)
  appointmentId Int           @unique
  patientId     Int
  userId        Int
  appointment   Appointment   @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  patient       Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoiceItems  InvoiceItem[]

  @@index([patientId])
}

model MedicalRecord {
  id            Int           @id @default(autoincrement())
  notes         String?
  diagnosis     String
  visitDate     DateTime      @default(now())
  userId        Int
  patientId     Int
  appointmentId Int           @unique
  needsFollowUp Boolean       @default(false)
  appointment   Appointment   @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  patient       Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  prescription  Prescription?

  @@index([userId])
  @@index([patientId])
}

model Prescription {
  id                      Int                      @id @default(autoincrement())
  status                  PrescriptionStatus       @default(PENDING)
  createdAt               DateTime                 @default(now())
  userId                  Int
  patientId               Int
  medicalRecordId         Int                      @unique
  appointmentId           Int
  appointment             Appointment              @relation(fields: [appointmentId], references: [id])
  medicalRecord           MedicalRecord            @relation(fields: [medicalRecordId], references: [id], onDelete: Cascade)
  patient                 Patient                  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  user                    User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  prescriptionMedications PrescriptionMedication[]

  @@index([userId])
  @@index([patientId])
}

model PrescriptionMedication {
  id             Int          @id @default(autoincrement())
  medicationId   Int
  prescriptionId Int
  dosage         Int
  frequency      Int
  duration       String
  medication     Medication   @relation(fields: [medicationId], references: [id], onDelete: Cascade)
  prescription   Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
}

model Triage {
  id            Int          @id @default(autoincrement())
  bloodPressure String?      @db.VarChar(20)
  temperature   Decimal?     @db.Decimal(4, 1)
  weight        Decimal?     @db.Decimal(5, 2)
  heartRate     Int?
  urgencyLevel  TriageStatus
  note          String?
  createdAt     DateTime     @default(now())
  appointmentId Int          @unique
  userId        Int
  appointment   Appointment  @relation(fields: [appointmentId], references: [id])
  user          User         @relation(fields: [userId], references: [id])
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model QueueHistory {
  id        Int         @id @default(autoincrement())
  queueId   Int
  userId    Int
  createdAt DateTime    @default(now())
  fromStage Stage?
  toStage   Stage
  action    QueueAction
  queue     Queue       @relation(fields: [queueId], references: [id], onDelete: Cascade)
  user      User        @relation("QueueHistoryUser", fields: [userId], references: [id])
}

model Queue {
  id                  Int            @id @default(autoincrement())
  patientId           Int
  stage               Stage
  status              QueueStatus
  queueNumber         Int            
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  appointmentId       Int?           @unique
  currentUserId       Int?
  requiredSpecialtyId Int?
  appointment         Appointment?   @relation(fields: [appointmentId], references: [id])
  currentUser         User?          @relation("CurrentQueueUser", fields: [currentUserId], references: [id])
  patient             Patient        @relation(fields: [patientId], references: [id])
  requiredSpecialty   Specialty?     @relation(fields: [requiredSpecialtyId], references: [id])
  histories           QueueHistory[]
}

model playing_with_neon {
  id    Int    @id @default(autoincrement())
  name  String
  value Float? @db.Real
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum PaymentStatus {
  PAID
  UNPAID
  PARTIAL
}

enum PrescriptionStatus {
  PENDING
  SENT
  ACTIVE
  INACTIVE
  REJECTED
}

enum TriageStatus {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum Stage {
  RECEPTION
  TRIAGE
  DOCTOR
  LABORATORY
  PHARMACY
  BILLING
  COMPLETED
}

enum QueueStatus {
  WAITING
  PROCESSING
  COMPLETED
  CANCELLED
}

enum QueueAction {
  START
  COMPLETE
  TRANSFER
  CANCEL
  SKIP
}
